@model University.ViewModel.CoursesVM.CourseDetailsViewModel

@{
    ViewData["Title"] = "Delete Course";
}

<h2>Delete Course</h2>
<h3>Are you sure you want to delete this course?</h3>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Course ID</dt>
        <dd class="col-sm-10">@Model.CourseId</dd>

        <dt class="col-sm-2">Title</dt>
        <dd class="col-sm-10">@Model.Title</dd>

        <dt class="col-sm-2">Credits</dt>
        <dd class="col-sm-10">@Model.Credits</dd>

        <dt class="col-sm-2">Department</dt>
        <dd class="col-sm-10">@Model.Department?.DepartmentName</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="CourseId" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index">Back to List</a>
    </form>
</div>