@model IEnumerable<University.ViewModel.EnrollmentDateGroupViewModel>

@{
    ViewData["Title"] = "Student Body Statistics";
}

<h2 style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; font-weight: bold; margin-top: 20px;">Student Body Statistics</h2>

<table style="width: 100%; border-collapse: collapse; font-family: sans-serif; font-size: 1rem; margin-top: 20px;">
    <thead>
        <tr style="border-top: 1px solid #dee2e6; border-bottom: 1px solid #dee2e6;">
            <th style="text-align: left; padding: 15px 8px; color: #007bff; text-decoration: underline; font-weight: bold;">
                Enrollment Date
            </th>
            @* MUUDATUS SIIN: text-align: center *@
            <th style="text-align: center; padding: 15px 8px; font-weight: bold;">
                Students
            </th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr style="border-bottom: 1px solid #dee2e6;">
                <td style="padding: 12px 8px;">
                    @Html.DisplayFor(modelItem => item.EnrollmentDate)
                </td>
                @* MUUDATUS SIIN: text-align: center *@
                <td style="padding: 12px 8px; text-align: center;">
                    @item.StudentCount
                </td>
            </tr>
        }
    </tbody>
</table>